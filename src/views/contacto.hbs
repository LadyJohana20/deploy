<div class="container py-5">
  <div class="row">
    <div class="col-md-5 mb-4">
      <h2 class="section-title">Contacto</h2>
      <p class="text-muted mt-3">Estamos disponibles para ayudarte a elegir el producto perfecto para tu necesidad.</p>
      <div class="mt-4">
        <div class="d-flex align-items-start mb-3">
          <div style="background:var(--verde-claro); width:44px; height:44px; border-radius:10px; display:flex; align-items:center; justify-content:center; flex-shrink:0; margin-right:15px;">
            <i class="bi bi-telephone text-white"></i>
          </div>
          <div><strong style="color:var(--verde-oscuro);">Teléfono</strong><br><span class="text-muted">+57 1234567890</span></div>
        </div>
        <div class="d-flex align-items-start mb-3">
          <div style="background:var(--naranja); width:44px; height:44px; border-radius:10px; display:flex; align-items:center; justify-content:center; flex-shrink:0; margin-right:15px;">
            <i class="bi bi-envelope text-white"></i>
          </div>
          <div><strong style="color:var(--verde-oscuro);">Email</strong><br><span class="text-muted">ventas@carpaselfuerte.com</span></div>
        </div>
        <div class="d-flex align-items-start mb-3">
          <div style="background:var(--verde-medio); width:44px; height:44px; border-radius:10px; display:flex; align-items:center; justify-content:center; flex-shrink:0; margin-right:15px;">
            <i class="bi bi-clock text-white"></i>
          </div>
          <div><strong style="color:var(--verde-oscuro);">Horarios</strong><br><span class="text-muted">Lunes a Viernes 9:00 - 18:00 hs</span></div>
        </div>
      </div>
    </div>
    <div class="col-md-7">
      <div class="form-card">
        <h4 style="color:var(--verde-oscuro); font-weight:700; margin-bottom:1.5rem;">Envianos tu consulta</h4>
        <div class="mb-3">
          <label class="form-label">Nombre completo</label>
          <input type="text" class="form-control" placeholder="Tu nombre">
        </div>
        <div class="mb-3">
          <label class="form-label">Email</label>
          <input type="email" class="form-control" placeholder="tu@email.com">
        </div>
        <div class="mb-3">
          <label class="form-label">Asunto</label>
          <select class="form-select">
            <option>Consulta sobre productos</option>
            <option>Pedido mayorista</option>
            <option>Garantía y soporte</option>
            <option>Otro</option>
          </select>
        </div>
        <div class="mb-4">
          <label class="form-label">Mensaje</label>
          <textarea class="form-control" rows="4" placeholder="Contanos en qué podemos ayudarte..."></textarea>
        </div>
        <button class="btn-submit w-100" onclick="alert('¡Mensaje enviado! Te contactaremos pronto.')">
          <i class="bi bi-send me-2"></i>Enviar Consulta
        </button>
      </div>
    </div>
  </div>
</div>
