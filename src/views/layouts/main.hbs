<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/styles.css">
  {{#if estilos}}<link rel="stylesheet" href="/css/{{estilos}}">{{/if}}
  <title>Carpas El Fuerte {{#if titulo}}- {{titulo}}{{/if}}</title>
</head>
<body>

  {{> navegacion}}

  <!-- Overlay carrito -->
  <div class="overlay-carrito" id="overlayCarrito" onclick="cerrarCarrito()"></div>

  <!-- Sidebar Carrito -->
  <div class="carrito-sidebar" id="carritoSidebar">
    <div class="carrito-header">
      <h5><i class="bi bi-cart3 me-2"></i>Mi Carrito</h5>
      <button class="btn-cerrar-carrito" onclick="cerrarCarrito()">✕</button>
    </div>
    <div class="carrito-items" id="carritoItems">
      <div id="carritoVacio" class="text-center text-muted py-5">
        <i class="bi bi-cart-x" style="font-size:3rem;"></i>
        <p class="mt-3">Tu carrito está vacío</p>
      </div>
    </div>
    <div class="carrito-footer">
      <div class="carrito-total" id="carritoTotal">Total: <span>$0</span></div>
      <button class="btn-finalizar-compra" id="btnFinalizar" onclick="finalizarCompra()">
        🛒 Confirmar Pedido
      </button>
      <button class="btn-vaciar-carrito" onclick="vaciarCarrito()">
        <i class="bi bi-trash3 me-1"></i>Vaciar carrito
      </button>
    </div>
  </div>

  {{{ body }}}

  {{> footer}}

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/carrito.js"></script>
</body>
</html>
